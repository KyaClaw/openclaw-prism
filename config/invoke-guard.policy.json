{
  "host": "127.0.0.1",
  "port": 18767,
  "upstreamUrl": "http://127.0.0.1:18789",
  "upstreamTokenEnv": "OPENCLAW_GATEWAY_TOKEN",
  "defaultDenyTools": [
    "gateway",
    "nodes",
    "browser",
    "whatsapp_login",
    "sessions_spawn",
    "sessions_send",
    "cron"
  ],
  "scannerUrl": "http://127.0.0.1:18766/scan",
  "scannerTimeoutMs": 1200,
  "blockOnScannerFailure": true,
  "clients": [
    {
      "id": "example-api-client",
      "token": "replace-with-long-random-token",
      "allowedSessionPrefixes": ["agent:example:"],
      "allowTools": ["web_fetch", "read", "memory_search"],
      "denyTools": ["exec", "write", "edit", "apply_patch"]
    }
  ]
}
